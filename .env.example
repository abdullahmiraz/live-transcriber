# Copy to .env and adjust. Used by docker-compose.
# Full setup checklist: docs/getting-started.md
# URL reference after startup: docs/local-urls.md
# Grafana login: GRAFANA_USER / GRAFANA_PASSWORD (monitoring profile)

# --- Postgres ---
POSTGRES_USER=meetuser
POSTGRES_PASSWORD=meetpass
POSTGRES_DB=meetings

# --- Redis (realtime pub/sub) ---
# Internal only; never published. Leave default for docker-compose.
REDIS_URL=redis://redis:6379/0

# --- Backend ---
PORT=8080
LOG_LEVEL=info
# DATABASE_URL is assembled in docker-compose from the POSTGRES_* values.
DATABASE_URL=postgres://meetuser:meetpass@postgres:5432/meetings?sslmode=disable
CORS_ORIGINS=*
# Comma-separated origins, or * for dev/LAN (phones on same Wi‑Fi).
# PUBLIC_BASE_URL is optional; join links use the browser origin.
PUBLIC_BASE_URL=http://localhost

# AI providers: mock (default, no keys), whisper, deepgram, libretranslate, ...
STT_PROVIDER=mock
TRANSLATION_PROVIDER=mock
# Default caption target language used by the mock/translation layer.
DEFAULT_TARGET_LANG=ru

# Observability
OTEL_ENABLED=false

# --- Grafana (monitoring profile: docker compose --profile monitoring up) ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
# Auto-start Grafana + Prometheus with the app:
# COMPOSE_PROFILES=monitoring

# --- Frontend (build/runtime) ---
# Public base for API/WS as seen by the browser (through nginx).
PUBLIC_API_BASE=/api
PUBLIC_WS_URL=/ws
